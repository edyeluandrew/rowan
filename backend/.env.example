# ───── Server ─────
PORT=4000
NODE_ENV=development

# ───── Database (Supabase PostgreSQL) ─────
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ───── Redis (Upstash) ─────
REDIS_URL=redis://default:your-token@your-instance.upstash.io:6379

# ───── Stellar ─────
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
ESCROW_PUBLIC_KEY=G...
ESCROW_SECRET_KEY=S...

# Market Maker (testnet liquidity provisioning)
# Generate via: node scripts/setupMarketMaker.js
# Keep this SECRET — it controls the DEX liquidity account
MARKET_MAKER_SECRET_KEY=S...

# Optional dedicated testnet USDC treasury (defaults to MARKET_MAKER_SECRET_KEY if unset).
# Fund this account ONCE with real Circle testnet USDC: https://faucet.circle.com → Stellar Testnet
# Rowan then sends direct on-chain USDC payments to new tester wallets (Stellar payment op).
# TESTNET_FAUCET_SECRET_KEY=S...
# TESTNET_FAUCET_USDC_AMOUNT=100
# TESTNET_FAUCET_COOLDOWN_SECONDS=7200
# TESTNET_FAUCET_MIN_BALANCE=1

# USDC issuer addresses (defaults provided; override only for custom issuers)
# USDC_ISSUER_TESTNET=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# USDC_ISSUER_MAINNET=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# Max fee in stroops for Stellar transactions (default 10000 = 0.001 XLM)
# STELLAR_MAX_FEE=10000

# ───── SEP-10 / stellar.toml ─────
# Public key used as the SIGNING_KEY in /.well-known/stellar.toml.
# Generate a dedicated keypair: node -e "console.log(require('@stellar/stellar-sdk').Keypair.random().publicKey())"
SEP10_SIGNING_KEY=G...

# Public base URL of this API (no trailing slash). Used to build the
# WEB_AUTH_ENDPOINT in stellar.toml, e.g. https://api.rowan.app
API_URL=https://api.rowan.app

# ───── JWT (CRITICAL — server refuses to start without this) ─────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
# Shorter admin session in production (default 1h when NODE_ENV=production)
JWT_ADMIN_EXPIRES_IN=1h
JWT_TRADER_EXPIRES_IN=7d

# ───── Encryption (AES-256-GCM for PII + TOTP secrets at rest) ─────
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# ───── Platform Economics ─────
PLATFORM_FEE_PERCENT=1
PLATFORM_SPREAD_PERCENT=1.25
MAX_SLIPPAGE_PERCENT=5
# ↑ Set to 5 for testnet (higher slippage tolerance), 0.5 for mainnet
QUOTE_TTL_SECONDS=360

# ───── Test Traders (for development/testing) ─────
# Usage: node setup-test-trader.mjs
# 
# BATCH MODE: Multiple traders with TRADER1_*, TRADER2_*, etc.
# SINGLE MODE: Legacy single trader with TEST_TRADER_* (backwards compatible)
#
# BATCH MODE EXAMPLE (4 diverse traders):
# TRADER1_EMAIL=trader-mtb-airtel@test.com
# TRADER1_PASSWORD=trader123
# TRADER1_NAME=Trader MTB+Airtel
# TRADER1_METHODS=MTB,Airtel
# TRADER1_FLOAT_UGX=50000000
# TRADER1_FLOAT_KES=50000000
# TRADER1_FLOAT_TZS=50000000
#
# TRADER2_EMAIL=trader-airtel@test.com
# TRADER2_PASSWORD=trader123
# TRADER2_NAME=Trader Airtel Only
# TRADER2_METHODS=Airtel
# TRADER2_FLOAT_UGX=50000000
# TRADER2_FLOAT_KES=50000000
# TRADER2_FLOAT_TZS=50000000
# ... (repeat for TRADER3, TRADER4, etc.)
#
# SINGLE MODE EXAMPLE (legacy):
# TEST_TRADER_EMAIL=test.trader.flow@rowan.local
# TEST_TRADER_PASSWORD=TestFlow123!@#
# TEST_TRADER_PHONE=+256704888999
# TEST_TRADER_NAME=Test Trader Flow

# Legacy single trader configuration (SINGLE MODE)
TEST_TRADER_EMAIL=test.trader.flow@rowan.local
TEST_TRADER_PASSWORD=TestFlow123!@#
TEST_TRADER_PHONE=+256704888999
TEST_TRADER_NAME=Test Trader Flow
TRADER_ACCEPT_TIMEOUT_SECONDS=180
TRADER_CONFIRM_TIMEOUT_SECONDS=300
# Re-match attempts after trader accepts but does not submit MoMo payout
TRADER_REMATCH_MAX_ATTEMPTS=3
TRADER_RETRY_DELAY_SECONDS=30
RATE_CACHE_TTL_SECONDS=30

# Minimum XLM amount per cash-out (prevents dust transactions)
MIN_XLM_AMOUNT=2

# ───── USDC/Fiat Rates (STATIC fallback — testnet/demo; Phase 2H-4 live provider) ─────
# USDC_RATE_UGX=3750
# USDC_RATE_KES=153
# USDC_RATE_TZS=2650
# Mainnet: live FX required; STATIC blocked unless ALLOW_STATIC_FIAT_RATES=true
# ALLOW_STATIC_FIAT_RATES=true
# Live fiat FX provider (default: exchange-rate-api — UGX/KES/TZS via USD base)
# FIAT_FX_PROVIDER=exchange-rate-api
# FIAT_FX_PROVIDER=coingecko   # partial fiat only — UGX/TZS NOT supported; crypto XLM fallback only
# FIAT_FX_PROVIDER=none        # STATIC only (testnet)
# FIAT_FX_API_URL=https://open.er-api.com/v6/latest/USD
# FIAT_FX_ENABLED=true
# FX_RATE_CACHE_TTL_SECONDS=300
# FX_RATE_MAX_AGE_SECONDS=3600
# FIAT_FX_STALE_SECONDS=3600   # alias for FX_RATE_MAX_AGE_SECONDS
# ALLOW_STALE_FX_RATES=false   # mainnet must stay false

# Testnet orphan USDC recovery sweep destination (public key only; required for orphanRecoverySweep.mjs)
TESTNET_RECOVERY_WALLET_PUBLIC_KEY=G...

# ───── CORS ─────
# Comma-separated list of allowed frontend origins. No wildcards in production.
# The server refuses to start if this is not set.
CORS_ORIGIN=https://wallet.rowan.app,https://trader.rowan.app

# ───── Rate Limiting ─────
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_AUTH_MAX=20
# RATE_LIMIT_ADMIN_LOGIN_MAX=10
# RATE_LIMIT_TRADER_LOGIN_MAX=15
# RATE_LIMIT_2FA_VERIFY_MAX=15
# RATE_LIMIT_CASHOUT_STATUS_MAX=60
# RATE_LIMIT_SENSITIVE_ACTION_MAX=30

# ───── Admin Bootstrap (auto-seed admin on first boot) ─────
# ADMIN_EMAIL=admin@rowan.money
# ADMIN_PASSWORD=CHANGE_ME

# ───── CoinGecko (XLM crypto fallback in quoteEngine — NOT primary fiat FX for UGX/TZS) ─────
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# ───── Supabase Storage (private bucket for trader documents) ─────
# Your Supabase project URL (same project as DATABASE_URL)
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — bypasses RLS. NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# ───── Africa's Talking (SMS OTP delivery) ─────
# API key from your Africa's Talking dashboard
AT_API_KEY=your-at-api-key
# AT username — use 'sandbox' for dev/test
AT_USERNAME=sandbox
# Optional sender ID (registered shortcode); leave blank for shared shortcode
# AT_SENDER_ID=

# ───── Orphan Recovery ─────
# Timeout (minutes) before a FIAT_PAYOUT_SUBMITTED transaction (partner marked
# the manual mobile money payout sent, awaiting user receipt confirmation) is
# flagged as stuck for admin review.
ORPHAN_FIAT_SENT_MINUTES=60
# Timeout (minutes) before a TRADER_MATCHED transaction is unassigned and re-matched
ORPHAN_MATCHED_MINUTES=30

# ───── SMS Fallback (L-2) ─────
# Set to 'true' to enable SMS fallback for critical notifications
ENABLE_SMS_FALLBACK=false

# ───── Trader Verification ─────
# Minimum Binance P2P completed trades to pass threshold check
TRADER_MIN_P2P_TRADES=100
# Minimum Binance P2P completion rate (percent) to pass threshold check
TRADER_MIN_COMPLETION_RATE=95
# OTP code validity period in seconds (default 10 minutes)
TRADER_OTP_TTL_SECONDS=600
# Pre-signed document URL expiry in seconds (for admin review)
TRADER_DOC_URL_EXPIRY_SECONDS=900
# Current version of the trader agreement (must match file in static/)
TRADER_AGREEMENT_VERSION=v1.0
# Storage bucket name (Supabase Storage private bucket)
TRADER_DOC_BUCKET=trader-documents
