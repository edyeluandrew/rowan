# ───── Server ─────
PORT=4000
NODE_ENV=development

# ───── Database (Supabase PostgreSQL) ─────
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ───── Redis (Upstash) ─────
REDIS_URL=redis://default:your-token@your-instance.upstash.io:6379

# ───── Stellar ─────
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
ESCROW_PUBLIC_KEY=G...
ESCROW_SECRET_KEY=S...

# USDC issuer addresses (defaults provided; override only for custom issuers)
# USDC_ISSUER_TESTNET=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# USDC_ISSUER_MAINNET=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# Max fee in stroops for Stellar transactions (default 10000 = 0.001 XLM)
# STELLAR_MAX_FEE=10000

# ───── JWT (CRITICAL — server refuses to start without this) ─────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ───── Encryption (AES-256-GCM for PII — id_document_number) ─────
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# ───── Platform Economics ─────
PLATFORM_FEE_PERCENT=1
PLATFORM_SPREAD_PERCENT=1.25
MAX_SLIPPAGE_PERCENT=0.5
QUOTE_TTL_SECONDS=180
TRADER_ACCEPT_TIMEOUT_SECONDS=180
TRADER_CONFIRM_TIMEOUT_SECONDS=300
RATE_CACHE_TTL_SECONDS=30

# Minimum XLM amount per cash-out (prevents dust transactions)
MIN_XLM_AMOUNT=2

# ───── USDC/Fiat Rates (override for live FX in Phase 2) ─────
# USDC_RATE_UGX=3750
# USDC_RATE_KES=153
# USDC_RATE_TZS=2650

# ───── CORS ─────
# Comma-separated list of allowed frontend origins. No wildcards in production.
# The server refuses to start if this is not set.
CORS_ORIGIN=https://wallet.rowan.app,https://trader.rowan.app

# ───── Rate Limiting ─────
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_AUTH_MAX=20

# ───── Admin Bootstrap (auto-seed admin on first boot) ─────
# ADMIN_EMAIL=admin@rowan.money
# ADMIN_PASSWORD=CHANGE_ME

# ───── CoinGecko (fallback rate source) ─────
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# ───── Supabase Storage (private bucket for trader documents) ─────
# Your Supabase project URL (same project as DATABASE_URL)
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — bypasses RLS. NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# ───── Africa's Talking (SMS OTP delivery) ─────
# API key from your Africa's Talking dashboard
AT_API_KEY=your-at-api-key
# AT username — use 'sandbox' for dev/test
AT_USERNAME=sandbox
# Optional sender ID (registered shortcode); leave blank for shared shortcode
# AT_SENDER_ID=

# ───── Orphan Recovery ─────
# Timeout (minutes) before a FIAT_SENT transaction is flagged as stuck
ORPHAN_FIAT_SENT_MINUTES=60
# Timeout (minutes) before a TRADER_MATCHED transaction is unassigned and re-matched
ORPHAN_MATCHED_MINUTES=30

# ───── SMS Fallback (L-2) ─────
# Set to 'true' to enable SMS fallback for critical notifications
ENABLE_SMS_FALLBACK=false

# ───── Trader Verification ─────
# Minimum Binance P2P completed trades to pass threshold check
TRADER_MIN_P2P_TRADES=100
# Minimum Binance P2P completion rate (percent) to pass threshold check
TRADER_MIN_COMPLETION_RATE=95
# OTP code validity period in seconds (default 10 minutes)
TRADER_OTP_TTL_SECONDS=600
# Pre-signed document URL expiry in seconds (for admin review)
TRADER_DOC_URL_EXPIRY_SECONDS=900
# Current version of the trader agreement (must match file in static/)
TRADER_AGREEMENT_VERSION=v1.0
# Storage bucket name (Supabase Storage private bucket)
TRADER_DOC_BUCKET=trader-documents
