# Rowan user-web — Vite env (all client vars must start with VITE_)
#
# LOCAL: copy to .env and run `npm run dev`
# DEPLOY: set these in Vercel/Render/Netlify dashboard, then redeploy (baked in at build time)

# ── Required ──────────────────────────────────────────────────────────

# Backend API — no trailing slash
# Local:
# VITE_API_URL=http://localhost:4000
# Production (Render):
VITE_API_URL=https://rowan-1-9crb.onrender.com

# Stellar Horizon (testnet until mainnet cutover)
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# testnet | mainnet
VITE_STELLAR_NETWORK=testnet

# ── Optional ─────────────────────────────────────────────────────────

# SEP-10 home domain (hostname only, no https://)
# Omit if same host as VITE_API_URL — derived automatically from API URL.
# Local only:
# VITE_HOME_DOMAIN=localhost

# Support links (Help page)
# VITE_SUPPORT_WHATSAPP=+256792700303
# VITE_SUPPORT_EMAIL=support@rowan.app

# VITE_APP_VERSION=1.0.0

# USDC issuer overrides (usually not needed — backend quotes carry issuer)
# VITE_USDC_ISSUER_TESTNET=...
# VITE_USDC_ISSUER_MAINNET=...
