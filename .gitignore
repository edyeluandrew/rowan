# ==========================================
# ROWAN MONOREPO — ROOT GITIGNORE
# ==========================================
# This file prevents tracking of build artifacts, dependencies, and secrets
# across all 5 subfolders (backend, frontend, wallet, admin, rowan-mobile)

# ───── Node.js ─────
**/node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
pnpm-debug.log

# ───── Environment Variables ─────
# .env files are secret — NEVER commit
# .env.example files ARE committed for reference
**/.env
**/.env.local
**/.env.*.local

# ───── Build Outputs ─────
**/dist/
**/build/
**/www/
**/.next/
**/out/
**/.nuxt/

# ───── Logs ─────
**/logs/
**/*.log

# ───── IDE ─────
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# ───── OS ─────
.DS_Store
Thumbs.db
.AppleDesktop
ehthumbs.db

# ───── Android (rowan-mobile) ─────
**/android/build/
**/android/.gradle/
**/android/app/build/
**/android/app/.cxx/
**/android/.idea/
**/android/local.properties
**/android/.DS_Store

# ───── iOS (rowan-mobile) ─────
**/ios/Pods/
**/ios/Podfile.lock

# ───── Certificates & Keys ─────
# CRITICAL: Never commit SSL certificates or private keys
**/*.pem
**/*.key
**/*.cert
**/*.crt

# ───── Supabase Local ─────
**/.supabase/

# ───── Temp Files ─────
**/tmp/
**/temp/
**/*.orig
